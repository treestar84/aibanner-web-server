# Postgres 연결 (둘 중 하나)
# - Vercel Storage에서 생성 시: POSTGRES_URL 자동 주입됨
# - Neon 직접 생성 시: DATABASE_URL 사용
DATABASE_URL=
# POSTGRES_URL=  ← Vercel Storage 사용 시 자동 설정됨

# Upstash Redis (https://upstash.com)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Tavily Search API
TAVILY_API_KEY=

# Product Hunt API (선택)
PRODUCT_HUNT_TOKEN=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Cron 보호 (임의 문자열 설정)
CRON_SECRET=

# Admin 경로(/admin, /api/admin) 보호용 Basic Auth
# 비밀번호는 평문 대신 hash로 저장: npm run admin:hash -- "<password>" "<salt>"
ADMIN_BASIC_USER=admin
ADMIN_PASSWORD_SALT=
ADMIN_PASSWORD_HASH=

# Rate limiting (선택)
RATE_LIMIT_RPM=60

# Snapshot pipeline tuning (선택)
# UTC 기준 스케줄. 예: "0:17,9:17" = KST 09:17 / 18:17
PIPELINE_SCHEDULE_UTC=0:17,9:17
# 모드별 스케줄 (실시간/브리핑)
# PIPELINE_REALTIME_SCHEDULE_UTC=2:0,8:0,14:0,20:0 -> KST 05:00 / 11:00 / 17:00 / 23:00
PIPELINE_REALTIME_SCHEDULE_UTC=2:0,8:0,14:0,20:0
PIPELINE_BRIEFING_SCHEDULE_UTC=0:17,9:17
# 상세 처리 키워드 개수 (1~20)
PIPELINE_DETAILED_KEYWORDS=10
# 모드별 상세 처리 키워드 개수 (미설정 시 PIPELINE_DETAILED_KEYWORDS 사용)
PIPELINE_REALTIME_DETAILED_KEYWORDS=10
PIPELINE_BRIEFING_DETAILED_KEYWORDS=10
# 상세 키워드 처리 동시성
PIPELINE_KEYWORD_CONCURRENCY=3
# lightweight 저장 동시성
PIPELINE_LIGHTWEIGHT_CONCURRENCY=5
# 모드별 랭킹 시간 파라미터
PIPELINE_REALTIME_RECENCY_HALFLIFE_HOURS=9
PIPELINE_BRIEFING_RECENCY_HALFLIFE_HOURS=36
PIPELINE_REALTIME_VELOCITY_RECENT_HOURS=6
PIPELINE_REALTIME_VELOCITY_BASELINE_HOURS=18
PIPELINE_BRIEFING_VELOCITY_RECENT_HOURS=6
PIPELINE_BRIEFING_VELOCITY_BASELINE_HOURS=18
# 증분 수집 최소 윈도우(시간): 최신 누락 방지용
PIPELINE_SOURCE_MIN_WINDOW_HOURS=6
# 증분 상태가 없을 때 사용하는 초기 윈도우(시간)
PIPELINE_SOURCE_FALLBACK_WINDOW_HOURS=72
# 증분 윈도우 최대치(시간): 장시간 장애 복구 시 과도한 조회 제한
PIPELINE_SOURCE_MAX_WINDOW_HOURS=168
# 마지막 성공 시점 기준으로 재수집할 중첩 버퍼(분)
PIPELINE_SOURCE_OVERLAP_MINUTES=45
# 실시간 모드 증분 윈도우
PIPELINE_REALTIME_SOURCE_MIN_WINDOW_HOURS=6
PIPELINE_REALTIME_SOURCE_FALLBACK_WINDOW_HOURS=24
PIPELINE_REALTIME_SOURCE_MAX_WINDOW_HOURS=96
PIPELINE_REALTIME_SOURCE_OVERLAP_MINUTES=45
# 브리핑 모드 증분 윈도우
PIPELINE_BRIEFING_SOURCE_MIN_WINDOW_HOURS=24
PIPELINE_BRIEFING_SOURCE_FALLBACK_WINDOW_HOURS=72
PIPELINE_BRIEFING_SOURCE_MAX_WINDOW_HOURS=168
PIPELINE_BRIEFING_SOURCE_OVERLAP_MINUTES=45
# 신규 키워드 외부 enrichment 허용 여부
# realtime 모드는 공백 콘텐츠 방지를 위해 코드에서 항상 true로 동작
PIPELINE_BRIEFING_EXTERNAL_ENRICHMENT=true
# 수동 키워드 강제 노출 보정치
PIPELINE_MANUAL_KEYWORD_TOTAL_BONUS=6
PIPELINE_MANUAL_KEYWORD_INTERNAL_BONUS=3

# Tavily 검색 결과 수 (키워드당)
TAVILY_NEWS_RESULTS=5
TAVILY_WEB_RESULTS=5

# Data retention (선택)
# 상세 데이터(keywords/sources/snapshots) 보관일
RETENTION_DETAILED_DAYS=90
# 일별 집계(keyword_daily_stats) 보관일
RETENTION_AGGREGATE_DAYS=365
# 키워드 조회수 집계 생존 주기(일): 최근 N일 Top10 밖으로 벗어나면 삭제
RETENTION_KEYWORD_VIEW_DAYS=3

# 요약 비용/토큰 제어
ENABLE_EN_SUMMARY=true
SUMMARY_CONTEXT_LIMIT=5
# 요약 길이 목표(기본 440자)
# SUMMARY_MAX_CHARS=440
